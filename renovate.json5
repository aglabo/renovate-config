// cspell:words gomod

// ---
{
  // Renovate configuration schema
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",

  // Base configuration presets
  // config:recommended: Renovate recommended settings
  // :label(renovate): add "renovate" label to all PRs
  "extends": [
    "config:recommended",
    ":label(renovate)",
  ],

  "timezone": "Asia/Tokyo",

  // Enabled package managers
  "enabledManagers": [
    "github-actions",
    "deno",
    "npm",
    "pnpm",
  ],

  // PR creation schedule: every Monday 1am-3am
  "schedule": [
    "after 1am and before 3am on monday",
  ],

  // Automerge schedule: every Monday 3am-6am
  "automergeSchedule": [
    "after 3am and before 6am on monday",
  ],

  // PR rate limits
  // NOTE: README specifies no limit, but limits are applied for operational safety
  // prHourlyLimit: max PRs created per hour
  // prConcurrentLimit: max open PRs at a time
  "prHourlyLimit": 5,
  "prConcurrentLimit": 10,

  // Enable updates/rebases outside schedule for security fixes
  "updateNotScheduled": true,

  "dependencyDashboard": true,
  "dependencyDashboardApproval": false,

  "rebaseWhen": "behind-base-branch",
  "rollbackPrs": true,

  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 3am on monday"]
  }

  // Package rules: label assignment and automerge settings per update type
  "packageRules": [
    // major update: label only, automerge disabled
    {
      "matchUpdateTypes": ["major"],
      "addLabels": ["update: major"],
      "automerge": false,
      "minimumReleaseAge": "7 days",
      "dependencyDashboardApproval": true,
    },

    // minor update: label, automerge after 5 days from release
    {
      "matchUpdateTypes": ["minor"],
      "addLabels": ["update: minor"],
      "automerge": true,
      "minimumReleaseAge": "5 days",
    },

    // patch update: label, automerge after 3 days from release
    {
      "matchUpdateTypes": ["patch"],
      "addLabels": ["update: patch"],
      "automerge": true,
      "minimumReleaseAge": "3 days",
    },

    // pin update: label, automerge immediately
    {
      "matchUpdateTypes": ["pin"],
      "addLabels": ["update: pin"],
      "automerge": true,
    },

    // GitHub Actions: pin digest (SHA256) for all actions except actions/* namespace
    // Step 1: enable pinDigests for all GitHub Actions
    {
      "matchManagers": ["github-actions"],
      "pinDigests": true,
    },
    // Step 2: disable pinDigests for actions/* (official actions are managed by tags)
    {
      "matchManagers": ["github-actions"],
      "matchPackagePatterns": ["^actions/"],
      "pinDigests": false,
    },
  ],
}
